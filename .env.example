# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Gmail sending credentials
# IMPORTANT: Use a Gmail App Password, NOT your regular Gmail password
# Get one at: myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account)
SENDER_EMAIL=your_gmail@gmail.com
SENDER_EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Your identity for outreach emails (company name is always "Wholesale Omniverse")
SENDER_NAME=Your Name
SENDER_PHONE=555-000-0000

# ─── OMNIVERSE Animation Studio API Keys ─────────────────────────────────────

# Replicate — open-source animation models (Wan 2.1, Kling, AnimateDiff, SVD)
# Get key: replicate.com/account/api-tokens
REPLICATE_API_KEY=r8_your_key_here

# RunwayML Gen-3 Alpha Turbo — high-quality commercial video generation
# Get key: app.runwayml.com → Settings → API
RUNWAYML_API_KEY=your_runway_key_here

# Stability AI — Stable Video Diffusion
# Get key: platform.stability.ai/account/keys
STABILITY_API_KEY=sk-your_stability_key_here

# LumaLabs Dream Machine — physics-based high quality video
# Get key: lumalabs.ai/dream-machine/api
LUMALABS_API_KEY=your_luma_key_here

# ─── OMNIVERSE Dubbing / Text-to-Speech API Keys ─────────────────────────────

# ElevenLabs — BEST quality TTS, emotion control, voice cloning, 30+ languages (RECOMMENDED)
# Get key: elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# OpenAI TTS — fast clean voices (alloy, echo, fable, onyx, nova, shimmer), HD option
# Uses same key as OpenAI API — platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# gTTS (Google TTS) is FREE and requires NO API KEY — installed automatically
# Lower quality than ElevenLabs/OpenAI but works out of the box

# ─── Media Buyer agent (media_buyer/) ────────────────────────────────────────
# Autonomous Meta campaign optimizer. DRY_RUN by default; uncomment MB_LIVE only
# after reviewing a few entries in data/media_buyer/controller_audit.jsonl.

# Required for the lead-gen profile:
META_AD_ACCOUNT_ID=act_REPLACE_ME              # Business Manager → Ad Accounts
MB_LEADGEN_PIXEL_ID=REPLACE_ME                 # Events Manager → Pixels (15-16 digit numeric)
MB_LEADGEN_TARGET_CPL=25                       # Max acceptable cost per lead, USD
MB_LEADGEN_ALERT_EMAIL=your_email@example.com  # Daily report destination

# Required to subscribe Meta's leadgen webhook (any random string you choose,
# pasted into Meta when subscribing). Generate with: python3 -c "import secrets; print('mb_wh_'+secrets.token_hex(16))"
META_WEBHOOK_VERIFY_TOKEN=mb_wh_replace_with_random_hex

# Optional — uncomment ONLY after watching dry-run audit logs.
# MB_LIVE=1

# Optional — e-com profile (parallel set; only needed if running --kind ecom)
# MB_ECOM_AD_ACCOUNT_ID=act_...
# MB_ECOM_PIXEL_ID=...
# MB_ECOM_BREAKEVEN_ROAS=1.8
# MB_ECOM_TARGET_AOV=45
# MB_ECOM_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# MB_ECOM_ALERT_EMAIL=ops@example.com

# Optional — companion services the FastAPI webhook server depends on
# (run_media_buyer_server.py). Cron-only usage doesn't need these.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # required for lead-gen phone validation
# TWILIO_AUTH_TOKEN=your_twilio_token
# SHOPIFY_WEBHOOK_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxx    # required to verify Shopify order webhooks
# MB_CRM_WEBHOOK_URL=https://hooks.zapier.com/...           # optional CRM forward
# MB_LEADGEN_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# MB_WINNING_DAILY_THRESHOLD=25                              # alert when a SKU crosses this many orders/day

# Safety caps (defaults in code; only set to override)
# MB_MAX_DAILY_INCREASE_PCT=30                               # caps any single scale step
# MB_MAX_DAILY_BUDGET_USD=500                                # caps post-mutation absolute daily budget
